# ============================================================
# Skellington — Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control!
# ============================================================

# ------------------------------------------------------------
# LLM Providers (configure at least one)
# ------------------------------------------------------------

# Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-your-key-here

# OpenAI
OPENAI_API_KEY=sk-your-key-here

# Google Gemini
GOOGLE_API_KEY=your-google-api-key-here

# Default provider and model
DEFAULT_LLM_PROVIDER=anthropic
DEFAULT_LLM_MODEL=claude-opus-4-7

# Optional: per-agent model overrides
# JACK_MODEL=claude-opus-4-7
# SALLY_MODEL=claude-sonnet-4-5
# OOGIE_MODEL=gpt-4o
# ZERO_MODEL=claude-haiku-4-5
# VALIDATORS_MODEL=claude-sonnet-4-5
# MAYOR_MODEL=claude-haiku-4-5

# ------------------------------------------------------------
# Web Search (configure at least one for Oogie)
# ------------------------------------------------------------

BRAVE_SEARCH_API_KEY=your-brave-api-key-here
TAVILY_API_KEY=tvly-your-key-here

# ------------------------------------------------------------
# Local Models (optional)
# ------------------------------------------------------------

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=llama3.2

# ------------------------------------------------------------
# Application Settings
# ------------------------------------------------------------

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Agent memory database path
MEMORY_DB_PATH=./data/skellington_memory.db

# Maximum tokens per agent response
MAX_TOKENS=4096

# Web UI settings
WEB_HOST=0.0.0.0
WEB_PORT=8000
WEB_RELOAD=true

# ------------------------------------------------------------
# MCP Server Settings
# ------------------------------------------------------------

# Code execution sandbox timeout (seconds)
CODE_EXEC_TIMEOUT=30

# Filesystem MCP — allowed root paths (comma-separated)
FILESYSTEM_ALLOWED_PATHS=./,~/projects

# Web search results limit
SEARCH_RESULTS_LIMIT=10